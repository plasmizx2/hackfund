# Copy to .env.local — values from Supabase → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
#
# If OAuth callback logs "unable to get local issuer certificate", Node can't verify
# HTTPS to Supabase (same class of issue as npm). Try: npm run dev:openssl-ca
# Local-only last resort: npm run dev:insecure (never use in production).
#
# OAuth: Authentication → Sign In / Providers → enable Google and/or GitHub.
# Authentication → URL Configuration → add redirect:
#   http://localhost:3000/auth/callback
# Production (Render, etc.):
#   https://<your-service>.onrender.com/auth/callback
# Same URL in Google/GitHub OAuth allowed redirect URIs if you use those providers.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional but recommended on production (Render): canonical site URL for OAuth return.
# Stops sign-in from using a wrong origin (e.g. https://localhost:10000 from IDE preview).
# NEXT_PUBLIC_APP_URL=https://your-app.onrender.com

# Optional — “Polish & fill” assistant on new hackathon form
# Local (default): install https://ollama.com , then: ollama pull llama3.2
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# Or use OpenAI instead (takes precedence if set):
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
