# Copy to .env.local only if you run the app locally (optional).
# Production: set these in Render — see render.yaml.
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Public site URL, no trailing slash. Required for OAuth (set on Render as NEXT_PUBLIC_APP_URL).
# NEXT_PUBLIC_APP_URL=https://your-app.onrender.com

# Supabase → Authentication → URL Configuration:
#   Site URL: https://your-app.onrender.com
#   Redirect URLs: https://your-app.onrender.com/auth/callback
# Google Cloud OAuth “Authorized redirect URI” must include:
#   https://<project-ref>.supabase.co/auth/v1/callback

# Optional — “Polish & fill” on new hackathon form (OpenAI on Render; Ollama only if local)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
